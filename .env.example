# Lumi Bookkeeping — environment configuration.
# Copy this file to `.env` and fill in. `.env` is gitignored.
#
# With DATABASE_URL unset, the app runs on the local JSON file (dev only).
# Set it to switch to the durable PostgreSQL backend.

# PostgreSQL connection string (Neon / Supabase / Render / RDS).
# Neon example: postgres://user:pass@ep-xxx.eu-west-2.aws.neon.tech/lumi?sslmode=require
DATABASE_URL=

# Session signing secret — REQUIRED in production. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Set to "production" when deployed (enables secure cookies + trust proxy).
NODE_ENV=

# HTTP port (defaults to 4000).
PORT=4000
